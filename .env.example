PORT=3000
NODE_ENV=production

# ── JWT (generate strong random secrets!) ────────────────────────────────────
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Database (Railway sets DATABASE_URL automatically) ────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_SSL=true   ← раскомментируй для Railway/cloud

# ── CORS: твой Railway домен ──────────────────────────────────────────────────
ALLOWED_ORIGINS=https://YOUR-APP.up.railway.app,capacitor://localhost

# ── Vite build: Android APK будет обращаться сюда ────────────────────────────
VITE_API_URL=https://YOUR-APP.up.railway.app

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOADS_DIR=./uploads
MAX_UPLOAD_MB=20
