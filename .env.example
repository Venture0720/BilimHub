PORT=3000
NODE_ENV=development

# ── JWT ─────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_random_64_byte_hex_string_access
JWT_REFRESH_SECRET=replace_with_random_64_byte_hex_string_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Super admin credentials (created on first init-prod run) ─────────────────────
SUPER_ADMIN_EMAIL=super@educenter.kz
SUPER_ADMIN_PASSWORD=ChangeMe@2026!

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
# Option A — cloud connection string (Railway, Render, Supabase):
# DATABASE_URL=postgres://user:password@host:5432/dbname
# Option B — individual fields:
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=bilimhub
DB_USER=postgres
DB_PASSWORD=change_me_in_production
# DB_SSL=true                        # enable SSL for cloud DBs
# DB_SSL_REJECT_UNAUTHORIZED=false   # only if provider uses self-signed certs

# ── File uploads ────────────────────────────────────────────────────────────────
UPLOADS_DIR=./uploads
MAX_UPLOAD_MB=20
# Vercel Blob (for serverless deployments):
# BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# ── CORS (comma-separated origins) ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── App URL (used for forgot-password reset links) ───────────────────────────────
APP_URL=https://yourdomain.com

# ── SMTP (for email notifications — uncomment when ready) ───────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM="BilimHub <noreply@example.com>"
